{
  "name": "markdown-for-tistory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Chrome extension that adds Markdown writing and preview support to the Tistory editor.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "chrome-extension",
    "tistory",
    "markdown"
  ],
  "license": "ISC",
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.1.29",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/expect": "^4.1.2",
    "@vitest/runner": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.4.0",
    "jsdom": "^27.0.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^6.4.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "marked": "^17.0.5"
  }
}
